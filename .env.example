# Supabase public browser/server client.
# Required for real backend API data and Realtime sync.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only key.
# Never expose this in client code. Required by API route handlers that write
# games, rounds and questions.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic server-only key for AI answer evaluation.
# Leave empty only if OPENROUTER_API_KEY is configured.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter server-only key for AI answer evaluation.
# Preferred when configured.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Optional future research helper. Not used for real network search yet.
HISTORICAL_RESEARCH_API_KEY=
